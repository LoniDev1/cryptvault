{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CryptVault",
  "version": "0.1.4",
  "identifier": "io.cryptvault.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "CryptVault",
        "width": 1200,
        "height": 780,
        "minWidth": 980,
        "minHeight": 640,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Encrypted volumes and file vault",
    "longDescription": "Cross-platform encrypted container and file vault using authenticated cascade encryption."
  },
  "plugins": {}
}
